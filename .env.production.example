# Production environment example
# Copy values into Vercel project environment variables or .env.production.local

NODE_ENV=production

# Database
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Blob storage
# On Vercel, connect a Blob store with prefix BLOB so this exact variable is created.
BLOB_READ_WRITE_TOKEN="vercel_blob_..."

# Auth
NEXTAUTH_URL="https://your-store.vercel.app"
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Email / SMTP
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="orders@yourstore.com"

# Optional setup protection
SETUP_SECRET="replace-with-openssl-rand-base64-32"

# Fallback store defaults
ADMIN_EMAIL="admin@yourstore.com"
STORE_NAME="My Store"
STORE_EMAIL="info@yourstore.com"
STORE_PHONE=""
STORE_ADDRESS=""
STORE_CITY=""
STORE_STATE=""
STORE_ZIP=""
CURRENCY="USD"
TIMEZONE="America/New_York"

# Optional maintenance route protection
# MAINTENANCE_API_KEY="replace-me"
